KEYCLOAK_USER_PASSWORD=replace_me_password

# Login data
LOGIN_USER_banco=replace_me_login_user
LOGIN_PASSWORD_banco=replace_me_login_password
LOGIN_USER_CAMPAIGNS=replace_me_campaign_user
LOGIN_PASSWORD_CAMPAIGNS=replace_me_campaign_password
