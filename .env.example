# VPN for CI (Azure Pipelines)
VPN_USER=replace_me_vpn_user
VPN_PASSWORD=replace_me_vpn_password
VPN_GROUP=replace_me_vpn_group
VPN_GATEWAY=replace-me-vpn-gateway.example:443
VPN_SERVERCERT_PIN=replace_me_pin_sha256
