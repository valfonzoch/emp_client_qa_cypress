CYPRESS_PROJECT_ID=replace_me_project_id
CYPRESS_RECORD_KEY=replace_me_record_key

# App URLs
CYPRESS_BASE_URL=https://replace-me-app.example
CYPRESS_BASE_URL_CAMPAIGN=https://replace-me-campaign.example
CYPRESS_BASE_URL_API_ACCOUNT=https://replace-me-api-account.example
CYPRESS_BASE_URL_API_CARD=https://replace-me-api-card.example
CYPRESS_BASE_URL_API_PERSON=https://replace-me-api-person.example
CYPRESS_BASE_URL_API_DOCUMENT=https://replace-me-api-document.example
CYPRESS_BASE_URL_INFORMCONF=https://replace-me-informconf.example

# Keycloak / OAuth
KEYCLOAK_TOKEN_URL=https://replace-me-keycloak.example/realms/replace-me/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=replace_me_client_id
KEYCLOAK_CLIENT_SECRET=replace_me_client_secret
KEYCLOAK_USER_CLIENT_ID=replace_me_user_client_id
